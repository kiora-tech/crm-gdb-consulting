{# Carte des statistiques #}
<div class="col-xxl-3 col-md-6">
    <div class="card info-card h-100">
        <div class="card-body pb-0">
            <h5 class="card-title">{{ 'dashboard.stats'|trans }}</h5>

            <div class="row">
                <div class="col-6 mb-2">
                    <div class="d-flex align-items-center">
                        <div class="card-icon rounded-circle d-flex align-items-center justify-content-center bg-primary me-2" style="width: 40px; height: 40px; min-width: 40px;">
                            <i class="bi bi-people text-white"></i>
                        </div>
                        <div class="text-start">
                            <h6 class="mb-0">{{ totalCustomers }}</h6>
                            <span class="text-muted small">{{ 'dashboard.total_clients'|trans }}</span>
                        </div>
                    </div>
                </div>

                <div class="col-6 mb-2">
                    <div class="d-flex align-items-center">
                        <div class="card-icon rounded-circle d-flex align-items-center justify-content-center bg-warning me-2" style="width: 40px; height: 40px; min-width: 40px;">
                            <i class="bi bi-hourglass-split text-white"></i>
                        </div>
                        <div class="text-start">
                            <h6 class="mb-0">{{ inProgressCustomers }}</h6>
                            <span class="text-muted small">{{ 'dashboard.clients_in_progress'|trans }}</span>
                        </div>
                    </div>
                </div>

                <div class="col-6 mb-2">
                    <div class="d-flex align-items-center">
                        <div class="card-icon rounded-circle d-flex align-items-center justify-content-center bg-success me-2" style="width: 40px; height: 40px; min-width: 40px;">
                            <i class="bi bi-check-circle text-white"></i>
                        </div>
                        <div class="text-start">
                            <h6 class="mb-0">{{ wonCustomers }}</h6>
                            <span class="text-muted small">{{ 'dashboard.clients_won'|trans }}</span>
                        </div>
                    </div>
                </div>

                <div class="col-6 mb-2">
                    <div class="d-flex align-items-center">
                        <div class="card-icon rounded-circle d-flex align-items-center justify-content-center bg-danger me-2" style="width: 40px; height: 40px; min-width: 40px;">
                            <i class="bi bi-x-circle text-white"></i>
                        </div>
                        <div class="text-start">
                            <h6 class="mb-0">{{ lostCustomers }}</h6>
                            <span class="text-muted small">{{ 'dashboard.clients_lost'|trans }}</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="text-center mt-1 mb-3">
                <a href="{{ path('app_customer_index') }}" class="btn btn-primary btn-sm">
                    {{ 'dashboard.view_all_clients'|trans }}
                </a>
            </div>
        </div>
    </div>
</div>